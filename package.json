{
  "name": "vetroscope-home-sync",
  "version": "0.1.0-beta.2",
  "description": "Self-hosted sync server for Vetroscope — the privacy-first alternative to Vetroscope Cloud.",
  "license": "Apache-2.0",
  "homepage": "https://vetroscope.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/rankin-works/vetroscope-home-sync.git"
  },
  "bugs": {
    "url": "https://github.com/rankin-works/vetroscope-home-sync/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"*.md\" \"docs/**/*.md\"",
    "prepare": "node scripts/install-git-hooks.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
